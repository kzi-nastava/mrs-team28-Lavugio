<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_white_rounded"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reported by: "
            android:textSize="12sp"
            android:textColor="@color/medium_brown"
            android:fontFamily="@font/inter_variable_font"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/reporterNameTextView"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Jane Doe"
            android:textSize="12sp"
            android:textColor="@color/dark_green"
            android:fontFamily="@font/inter_variable_font" />
    </LinearLayout>

    <TextView
        android:id="@+id/reportMessageTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Driver took a different route than expected."
        android:textSize="14sp"
        android:textColor="@color/dark_green"
        android:fontFamily="@font/inter_variable_font" />

</LinearLayout>
