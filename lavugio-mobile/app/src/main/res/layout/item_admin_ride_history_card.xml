<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/lavugio_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Start and End Date Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- Start Date -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start"
                    android:textSize="12sp"
                    android:textColor="@color/medium_brown"
                    android:fontFamily="@font/inter_variable_font"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/startDateTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01.01.2024"
                    android:textSize="14sp"
                    android:textColor="@color/dark_green"
                    android:fontFamily="@font/inter_variable_font" />

                <TextView
                    android:id="@+id/startTimeTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10:30"
                    android:textSize="12sp"
                    android:textColor="@color/medium_brown"
                    android:fontFamily="@font/inter_variable_font" />

            </LinearLayout>

            <!-- End Date -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="End"
                    android:textSize="12sp"
                    android:textColor="@color/medium_brown"
                    android:fontFamily="@font/inter_variable_font"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/endDateTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01.01.2024"
                    android:textSize="14sp"
                    android:textColor="@color/dark_green"
                    android:fontFamily="@font/inter_variable_font" />

                <TextView
                    android:id="@+id/endTimeTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11:30"
                    android:textSize="12sp"
                    android:textColor="@color/medium_brown"
                    android:fontFamily="@font/inter_variable_font" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_brown"
            android:layout_marginBottom="8dp" />

        <!-- Route Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pickup"
                android:textSize="12sp"
                android:textColor="@color/medium_brown"
                android:fontFamily="@font/inter_variable_font"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/departureTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="123 Main Street, City"
                android:textSize="14sp"
                android:textColor="@color/dark_green"
                android:fontFamily="@font/inter_variable_font"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Destination"
                android:textSize="12sp"
                android:textColor="@color/medium_brown"
                android:fontFamily="@font/inter_variable_font"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/destinationTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="456 Park Avenue, City"
                android:textSize="14sp"
                android:textColor="@color/dark_green"
                android:fontFamily="@font/inter_variable_font"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Price and Status Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Price -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price"
                    android:textSize="12sp"
                    android:textColor="@color/medium_brown"
                    android:fontFamily="@font/inter_variable_font"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/priceTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500.00 RSD"
                    android:textSize="16sp"
                    android:textColor="@color/dark_brown"
                    android:fontFamily="@font/inter_variable_font"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Cancelled -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancelled"
                    android:textSize="12sp"
                    android:textColor="@color/medium_brown"
                    android:fontFamily="@font/inter_variable_font"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/cancelledTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_variable_font"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Panic -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Panic"
                    android:textSize="12sp"
                    android:textColor="@color/medium_brown"
                    android:fontFamily="@font/inter_variable_font"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/panicTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_variable_font"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
