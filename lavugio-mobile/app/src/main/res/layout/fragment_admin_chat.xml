<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FEFAE0">

    <!-- User picker (admin only) -->
    <LinearLayout
        android:id="@+id/layoutUserPicker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#606C38"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Spinner
            android:id="@+id/spinnerUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp" />
    </LinearLayout>

    <!-- Container for MessageBoxFragment -->
    <FrameLayout
        android:id="@+id/chatContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Placeholder shown when no user is selected -->
    <TextView
        android:id="@+id/tvNoSelection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Select a user to start chatting"
        android:textColor="#606C38"
        android:textSize="15sp"
        android:visibility="gone" />

</LinearLayout>