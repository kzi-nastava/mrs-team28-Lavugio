<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    app:cardBackgroundColor="#FEFAE0"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Zelena ivica za aktivne vožnje -->
        <View
            android:id="@+id/activeIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#606C38"
            android:layout_marginEnd="12dp"
            android:visibility="gone" />

        <!-- Sadržaj kartice -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Info sekcija -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <!-- Departure Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="Departure time:"
                        android:textColor="#283618"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_gravity="top" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/textViewDepartureTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text="Loading..."
                        android:textColor="#BC6C25"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Start Address -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="Start address:"
                        android:textColor="#283618"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_gravity="top" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/textViewStartAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text="Loading..."
                        android:textColor="#BC6C25"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="end" />
                </LinearLayout>

                <!-- End Address -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="End address:"
                        android:textColor="#283618"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_gravity="top" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/textViewEndAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text="Loading..."
                        android:textColor="#BC6C25"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Price -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="Price:"
                        android:textColor="#283618"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_gravity="top" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/textViewPrice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text="Loading..."
                        android:textColor="#BC6C25"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>

            <!-- Dugmad sekcija -->
            <LinearLayout
                android:id="@+id/buttonsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Panic Button -->
                <Button
                    android:id="@+id/buttonPanic"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="4dp"
                    android:text="🚨 PANIC"
                    android:textSize="10sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/button_panic"
                    app:backgroundTint="@null"
                    android:fontFamily="sans-serif-black"
                    android:textAllCaps="true"
                    android:visibility="gone"
                    />

                <!-- Alert Sent Text -->
                <TextView
                    android:id="@+id/textViewAlertSent"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="4dp"
                    android:text="✓ ALERT SENT"
                    android:textSize="10sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/button_alert_sent"
                    android:gravity="center"
                    android:fontFamily="sans-serif-black"
                    android:visibility="gone" />

                <!-- Finish Early Button -->
                <Button
                    android:id="@+id/buttonFinishEarly"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="4dp"
                    android:text="Finish early"
                    android:textSize="11sp"
                    android:textColor="#283618"
                    android:background="@drawable/button_finish_early"
                    app:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    />

                <!-- Finish Button -->
                <Button
                    android:id="@+id/buttonFinish"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="4dp"
                    android:text="Finish"
                    android:textSize="11sp"
                    android:textColor="#FEFAE0"
                    android:background="@drawable/button_finish"
                    app:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    />

                <!-- Deny Button -->
                <Button
                    android:id="@+id/buttonDeny"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="4dp"
                    android:text="Deny"
                    android:textSize="11sp"
                    android:textColor="#283618"
                    android:background="@drawable/button_deny"
                    app:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    />

                <!-- Start Button -->
                <Button
                    android:id="@+id/buttonStart"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Start"
                    android:textSize="11sp"
                    android:textColor="#FEFAE0"
                    android:background="@drawable/button_start"
                    app:backgroundTint="@null"
                    android:textAllCaps="false"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>