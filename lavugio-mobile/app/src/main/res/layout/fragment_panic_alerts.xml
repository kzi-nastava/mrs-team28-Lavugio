<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#283618"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🚨 Panic Alerts"
            android:textColor="#FEFAE0"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/btn_clear_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear All"
            android:textSize="12sp"
            android:textColor="#FEFAE0"
            android:backgroundTint="#BC6C25"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_no_alerts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No panic alerts at the moment."
        android:textColor="#606060"
        android:textSize="15sp"
        android:gravity="center"
        android:visibility="visible" />

    <!-- Alerts list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_panic_alerts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        android:visibility="gone" />

</LinearLayout>
